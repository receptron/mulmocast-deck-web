{
  "name": "@mulmocast/deck-web",
  "version": "0.5.0",
  "description": "Vue 3 components for editing @mulmocast/deck SlideLayout decks live in the browser",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/receptron/mulmocast-deck-web.git"
  },
  "bugs": {
    "url": "https://github.com/receptron/mulmocast-deck-web/issues"
  },
  "homepage": "https://github.com/receptron/mulmocast-deck-web#readme",
  "keywords": [
    "mulmocast",
    "deck",
    "slide",
    "vue",
    "editor",
    "tailwind"
  ],
  "main": "./dist/lib/index.js",
  "module": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    }
  },
  "files": [
    "dist/lib"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:lib": "BUILD_TARGET=lib vue-tsc -b && BUILD_TARGET=lib vite build",
    "preview": "vite preview",
    "lint": "eslint src test",
    "test": "tsx --test ./test/**/test_*.ts",
    "format": "prettier --write '{src,test}/**/*.{ts,vue,css}'",
    "prepublishOnly": "yarn run build:lib"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "@mulmocast/deck": "^0.5.1",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mulmocast/deck": "^0.7.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.1",
    "vue": "^3.5.34",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.3"
  }
}
